# 🚗 Car Price Exploratory Data Analysis (EDA) Project

# =========================
# 1. Import Libraries
# =========================

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# Display plots inside notebook
%matplotlib inline

# Style
sns.set_style("whitegrid")

print("Libraries imported successfully!")


# =========================
# 2. Load Dataset
# =========================

df = pd.read_csv("car_data.csv")

print("Dataset loaded successfully!")


# =========================
# 3. View Dataset
# =========================

# First 5 rows
print("\nFirst 5 Rows:")
print(df.head())

# Last 5 rows
print("\nLast 5 Rows:")
print(df.tail())

# Dataset shape
print("\nDataset Shape:")
print(df.shape)

# Column names
print("\nColumn Names:")
print(df.columns)

# Dataset information
print("\nDataset Information:")
print(df.info())


# =========================
# 4. Check Missing Values
# =========================

print("\nMissing Values:")
print(df.isnull().sum())


# =========================
# 5. Check Duplicate Rows
# =========================

print("\nDuplicate Rows:")
print(df.duplicated().sum())

# Remove duplicates
df.drop_duplicates(inplace=True)

print("\nDataset Shape After Removing Duplicates:")
print(df.shape)


# =========================
# 6. Statistical Summary
# =========================

print("\nStatistical Summary:")
print(df.describe())


# =========================
# 7. Fuel Type Distribution
# =========================

plt.figure(figsize=(8,5))

sns.countplot(x='Fuel_Type', data=df)

plt.title("Fuel Type Distribution")
plt.xlabel("Fuel Type")
plt.ylabel("Count")

plt.show()


# =========================
# 8. Transmission Distribution
# =========================

plt.figure(figsize=(8,5))

sns.countplot(x='Transmission', data=df)

plt.title("Transmission Type Distribution")
plt.xlabel("Transmission")
plt.ylabel("Count")

plt.show()


# =========================
# 9. Selling Price Distribution
# =========================

plt.figure(figsize=(10,6))

sns.histplot(df['Selling_Price'], bins=10, kde=True)

plt.title("Selling Price Distribution")
plt.xlabel("Selling Price")
plt.ylabel("Frequency")

plt.show()


# =========================
# 10. Mileage Distribution
# =========================

plt.figure(figsize=(10,6))

sns.histplot(df['Mileage'], bins=10, kde=True)

plt.title("Mileage Distribution")
plt.xlabel("Mileage")
plt.ylabel("Frequency")

plt.show()


# =========================
# 11. Mileage vs Selling Price
# =========================

plt.figure(figsize=(10,6))

sns.scatterplot(
    x='Mileage',
    y='Selling_Price',
    data=df
)

plt.title("Mileage vs Selling Price")
plt.xlabel("Mileage")
plt.ylabel("Selling Price")

plt.show()


# =========================
# 12. Year vs Selling Price
# =========================

plt.figure(figsize=(10,6))

sns.scatterplot(
    x='Year',
    y='Selling_Price',
    data=df
)

plt.title("Year vs Selling Price")
plt.xlabel("Year")
plt.ylabel("Selling Price")

plt.show()


# =========================
# 13. Boxplot
# =========================

plt.figure(figsize=(10,6))

sns.boxplot(x='Fuel_Type', y='Selling_Price', data=df)

plt.title("Fuel Type vs Selling Price")

plt.show()


# =========================
# 14. Correlation Heatmap
# =========================

plt.figure(figsize=(10,6))

numeric_df = df.select_dtypes(include=np.number)

sns.heatmap(
    numeric_df.corr(),
    annot=True,
    cmap='coolwarm'
)

plt.title("Correlation Heatmap")

plt.show()


# =========================
# 15. Pairplot
# =========================

sns.pairplot(df)

plt.show()


# =========================
# 16. Grouped Analysis
# =========================

avg_price = df.groupby('Fuel_Type')['Selling_Price'].mean()

print("\nAverage Selling Price by Fuel Type:")
print(avg_price)


# =========================
# 17. Top Expensive Cars
# =========================

top_cars = df.sort_values(by='Selling_Price', ascending=False)

print("\nTop Expensive Cars:")
print(top_cars[['Car_Name', 'Selling_Price']].head())


# =========================
# 18. Save Cleaned Dataset
# =========================

df.to_csv("cleaned_car_data.csv", index=False)

print("\nCleaned dataset saved successfully!")


# =========================
# 19. Final Insights
# =========================

print("\n========== PROJECT INSIGHTS ==========")

print("""
1. Newer cars generally have higher selling prices.

2. Diesel and automatic cars tend to cost more.

3. Engine capacity positively affects car prices.

4. Mileage has moderate impact on selling price.

5. Most cars in the dataset use petrol fuel type.
""")

print("========== END OF PROJECT ==========")
